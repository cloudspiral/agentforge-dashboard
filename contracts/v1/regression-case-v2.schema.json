{
  "$defs": {
    "ApprovedHttpMethodV1": {
      "enum": [
        "GET",
        "POST"
      ],
      "title": "ApprovedHttpMethodV1",
      "type": "string"
    },
    "AuthenticateActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "authenticate",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_role": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Expected Role",
          "type": "string"
        },
        "session_source": {
          "$ref": "#/$defs/AuthenticationSessionSourceV1"
        },
        "test_identity_alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Test Identity Alias",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "session_source",
        "test_identity_alias",
        "expected_role"
      ],
      "title": "AuthenticateActionV1",
      "type": "object"
    },
    "AuthenticationSessionSourceV1": {
      "enum": [
        "environment_credentials",
        "ephemeral_saved_test_session"
      ],
      "title": "AuthenticationSessionSourceV1",
      "type": "string"
    },
    "CollectEvidenceActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "collect_evidence",
          "title": "Action Type",
          "type": "string"
        },
        "capture_on": {
          "default": "always",
          "enum": [
            "always",
            "failure",
            "confirmed_signal"
          ],
          "title": "Capture On",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_kinds": {
          "items": {
            "$ref": "#/$defs/EvidenceKindV1"
          },
          "maxItems": 6,
          "minItems": 1,
          "title": "Evidence Kinds",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "evidence_kinds"
      ],
      "title": "CollectEvidenceActionV1",
      "type": "object"
    },
    "EvidenceKindV1": {
      "enum": [
        "transcript",
        "http_metadata",
        "tool_calls",
        "side_effects",
        "screenshot",
        "browser_trace"
      ],
      "title": "EvidenceKindV1",
      "type": "string"
    },
    "InvokeApprovedApiRequestActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "invoke_approved_api_request",
          "title": "Action Type",
          "type": "string"
        },
        "body": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Body",
          "type": "object"
        },
        "correlation_mode": {
          "default": "valid",
          "enum": [
            "valid",
            "missing",
            "invalid",
            "mismatch"
          ],
          "title": "Correlation Mode",
          "type": "string"
        },
        "credential_mode": {
          "default": "endpoint_default",
          "enum": [
            "endpoint_default",
            "missing",
            "invalid",
            "valid"
          ],
          "title": "Credential Mode",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "endpoint_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Endpoint Id",
          "type": "string"
        },
        "method": {
          "$ref": "#/$defs/ApprovedHttpMethodV1"
        },
        "query": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "maxProperties": 25,
          "title": "Query",
          "type": "object"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "endpoint_id",
        "method"
      ],
      "title": "InvokeApprovedApiRequestActionV1",
      "type": "object"
    },
    "JsonValue": {},
    "OwaspMappingsV1": {
      "additionalProperties": false,
      "description": "Explicitly versioned OWASP mappings; versions may not be implicit.",
      "properties": {
        "llm_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Llm Top 10",
          "type": "array"
        },
        "llm_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Llm Top 10 Version",
          "type": "string"
        },
        "web_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Web Top 10",
          "type": "array"
        },
        "web_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Web Top 10 Version",
          "type": "string"
        }
      },
      "required": [
        "web_top_10_version",
        "llm_top_10_version"
      ],
      "title": "OwaspMappingsV1",
      "type": "object"
    },
    "RegressionSetupV1": {
      "additionalProperties": false,
      "properties": {
        "expected_role": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Expected Role",
          "type": "string"
        },
        "requires_approved_upload_fixture": {
          "title": "Requires Approved Upload Fixture",
          "type": "boolean"
        },
        "reset_strategy_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Reset Strategy Id",
          "type": "string"
        },
        "selected_patient_alias": {
          "enum": [
            "patient_a",
            "patient_b"
          ],
          "title": "Selected Patient Alias",
          "type": "string"
        },
        "test_identity_alias": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Test Identity Alias",
          "type": "string"
        }
      },
      "required": [
        "reset_strategy_id",
        "test_identity_alias",
        "expected_role",
        "selected_patient_alias",
        "requires_approved_upload_fixture"
      ],
      "title": "RegressionSetupV1",
      "type": "object"
    },
    "RegressionTargetRequirementsV1": {
      "additionalProperties": false,
      "properties": {
        "source_target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Source Target Version",
          "type": "string"
        },
        "synthetic_only": {
          "const": true,
          "default": true,
          "title": "Synthetic Only",
          "type": "boolean"
        },
        "target_profile_version": {
          "maxLength": 255,
          "minLength": 1,
          "title": "Target Profile Version",
          "type": "string"
        }
      },
      "required": [
        "target_profile_version",
        "source_target_version"
      ],
      "title": "RegressionTargetRequirementsV1",
      "type": "object"
    },
    "ResetSessionActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "reset_session",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "require_clean_context": {
          "default": true,
          "title": "Require Clean Context",
          "type": "boolean"
        },
        "reset_strategy_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Reset Strategy Id",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "reset_strategy_id"
      ],
      "title": "ResetSessionActionV1",
      "type": "object"
    },
    "SelectSyntheticPatientActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "select_synthetic_patient",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "patient_alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Patient Alias",
          "type": "string"
        },
        "verify_selected_context": {
          "default": true,
          "title": "Verify Selected Context",
          "type": "boolean"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "patient_alias"
      ],
      "title": "SelectSyntheticPatientActionV1",
      "type": "object"
    },
    "SendChatMessageActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "send_chat_message",
          "title": "Action Type",
          "type": "string"
        },
        "await_response": {
          "default": true,
          "title": "Await Response",
          "type": "boolean"
        },
        "conversation_alias": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conversation Alias"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "message": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "message"
      ],
      "title": "SendChatMessageActionV1",
      "type": "object"
    },
    "UploadApprovedFixtureActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "upload_approved_fixture",
          "title": "Action Type",
          "type": "string"
        },
        "declared_media_type": {
          "maxLength": 100,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9.+-]+/[A-Za-z0-9.+-]+$",
          "title": "Declared Media Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "fixture_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Fixture Id",
          "type": "string"
        },
        "upload_surface_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Upload Surface Id",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "fixture_id",
        "upload_surface_id",
        "declared_media_type"
      ],
      "title": "UploadApprovedFixtureActionV1",
      "type": "object"
    },
    "WaitForResponseActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "wait_for_response",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_event": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Event"
        },
        "timeout_seconds": {
          "exclusiveMinimum": 0.0,
          "maximum": 120.0,
          "title": "Timeout Seconds",
          "type": "number"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "timeout_seconds"
      ],
      "title": "WaitForResponseActionV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "active": {
      "default": true,
      "title": "Active",
      "type": "boolean"
    },
    "case_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Case Id",
      "type": "string"
    },
    "case_version": {
      "minimum": 1,
      "title": "Case Version",
      "type": "integer"
    },
    "category": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Category",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_from_evidence_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Created From Evidence Hash",
      "type": "string"
    },
    "exact_ordered_sequence": {
      "items": {
        "discriminator": {
          "mapping": {
            "authenticate": "#/$defs/AuthenticateActionV1",
            "collect_evidence": "#/$defs/CollectEvidenceActionV1",
            "invoke_approved_api_request": "#/$defs/InvokeApprovedApiRequestActionV1",
            "reset_session": "#/$defs/ResetSessionActionV1",
            "select_synthetic_patient": "#/$defs/SelectSyntheticPatientActionV1",
            "send_chat_message": "#/$defs/SendChatMessageActionV1",
            "upload_approved_fixture": "#/$defs/UploadApprovedFixtureActionV1",
            "wait_for_response": "#/$defs/WaitForResponseActionV1"
          },
          "propertyName": "action_type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/ResetSessionActionV1"
          },
          {
            "$ref": "#/$defs/AuthenticateActionV1"
          },
          {
            "$ref": "#/$defs/SelectSyntheticPatientActionV1"
          },
          {
            "$ref": "#/$defs/SendChatMessageActionV1"
          },
          {
            "$ref": "#/$defs/UploadApprovedFixtureActionV1"
          },
          {
            "$ref": "#/$defs/InvokeApprovedApiRequestActionV1"
          },
          {
            "$ref": "#/$defs/WaitForResponseActionV1"
          },
          {
            "$ref": "#/$defs/CollectEvidenceActionV1"
          }
        ]
      },
      "maxItems": 30,
      "minItems": 6,
      "title": "Exact Ordered Sequence",
      "type": "array"
    },
    "expected_behavior": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Expected Behavior",
      "type": "string"
    },
    "finding_id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Finding Id",
      "type": "string"
    },
    "finding_key": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Finding Key",
      "type": "string"
    },
    "fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Fingerprint",
      "type": "string"
    },
    "judge_context": {
      "additionalProperties": true,
      "title": "Judge Context",
      "type": "object"
    },
    "owasp_mappings": {
      "$ref": "#/$defs/OwaspMappingsV1"
    },
    "required_replays": {
      "const": 2,
      "default": 2,
      "title": "Required Replays",
      "type": "integer"
    },
    "schema_version": {
      "const": "v2",
      "default": "v2",
      "title": "Schema Version",
      "type": "string"
    },
    "sequence_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Sequence Hash",
      "type": "string"
    },
    "setup": {
      "$ref": "#/$defs/RegressionSetupV1"
    },
    "source_provenance": {
      "maxLength": 40,
      "minLength": 1,
      "title": "Source Provenance",
      "type": "string"
    },
    "subcategory": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Subcategory",
      "type": "string"
    },
    "target_requirements": {
      "$ref": "#/$defs/RegressionTargetRequirementsV1"
    },
    "vulnerability_id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Vulnerability Id",
      "type": "string"
    }
  },
  "required": [
    "case_id",
    "finding_id",
    "vulnerability_id",
    "finding_key",
    "source_provenance",
    "case_version",
    "category",
    "subcategory",
    "owasp_mappings",
    "setup",
    "exact_ordered_sequence",
    "judge_context",
    "expected_behavior",
    "target_requirements",
    "created_from_evidence_hash",
    "sequence_hash",
    "fingerprint",
    "created_at"
  ],
  "title": "RegressionCaseV2",
  "type": "object"
}
