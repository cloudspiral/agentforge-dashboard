      },
      "title": "Outcome Lanes",
      "type": "array"
    },
    "resilience_transitions": {
      "items": {
        "$ref": "#/$defs/ResilienceTransitionV2"
      },
      "title": "Resilience Transitions",
      "type": "array"
    },
    "schema_version": {
      "default": "v2",
      "title": "Schema Version",
      "type": "string"
    },
    "surface_capabilities": {
      "items": {
        "$ref": "#/$defs/SurfaceCapabilityFactV2"
      },
      "title": "Surface Capabilities",
      "type": "array"
    },
    "taxonomy_version": {
      "title": "Taxonomy Version",
      "type": "string"
    },
    "timeline": {
      "items": {
        "$ref": "#/$defs/TimelineFactV2"
      },
      "title": "Timeline",
      "type": "array"
    }
  },
  "required": [
    "generated_at",
    "taxonomy_version",
    "surface_capabilities",
    "coverage",
    "outcome_lanes",
    "finding_lifecycle",
    "resilience_transitions",
    "cost_summary",
    "cost_facts",
    "timeline"
  ],
  "title": "PlatformObservabilitySnapshotV2",
  "type": "object"
}
