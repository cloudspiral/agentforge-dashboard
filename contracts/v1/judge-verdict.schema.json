{
  "$defs": {
    "ExploitabilityV1": {
      "enum": [
        "high",
        "medium",
        "low",
        "not_applicable"
      ],
      "title": "ExploitabilityV1",
      "type": "string"
    },
    "JudgeVerdictKindV1": {
      "enum": [
        "exploit_confirmed",
        "partial_signal",
        "attack_blocked",
        "inconclusive"
      ],
      "title": "JudgeVerdictKindV1",
      "type": "string"
    },
    "SeverityV1": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational",
        "none"
      ],
      "title": "SeverityV1",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "expected_behavior": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Expected Behavior",
      "type": "string"
    },
    "exploitability": {
      "$ref": "#/$defs/ExploitabilityV1"
    },
    "observed_behavior": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Observed Behavior",
      "type": "string"
    },
    "rubric_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Rubric Hash",
      "type": "string"
    },
    "rubric_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Rubric Version",
      "type": "string"
    },
    "schema_version": {
      "const": "v1",
      "title": "Schema Version",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/SeverityV1"
    },
    "verdict": {
      "$ref": "#/$defs/JudgeVerdictKindV1"
    },
    "violated_security_invariants": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 50,
      "title": "Violated Security Invariants",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "verdict",
    "severity",
    "exploitability",
    "confidence",
    "observed_behavior",
    "expected_behavior",
    "rubric_version",
    "rubric_hash"
  ],
  "title": "JudgeVerdictV1",
  "type": "object"
}
