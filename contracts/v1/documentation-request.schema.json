{
  "$defs": {
    "ActionExecutionStatusV1": {
      "enum": [
        "succeeded",
        "rejected",
        "timed_out",
        "failed",
        "skipped"
      ],
      "title": "ActionExecutionStatusV1",
      "type": "string"
    },
    "AgentErrorCodeV1": {
      "enum": [
        "target_unreachable",
        "budget_exceeded",
        "rate_limited",
        "invalid_contract",
        "action_rejected",
        "agent_refusal",
        "agent_timeout",
        "judge_timeout",
        "no_findings_in_window",
        "duplicate_finding",
        "regression_detected",
        "authentication_failed",
        "reset_failed",
        "unexpected_internal_error"
      ],
      "title": "AgentErrorCodeV1",
      "type": "string"
    },
    "AgentErrorV1": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attempt Id"
        },
        "campaign_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Campaign Id"
        },
        "code": {
          "$ref": "#/$defs/AgentErrorCodeV1"
        },
        "correlation_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Correlation Id",
          "type": "string"
        },
        "message": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        },
        "sanitized_details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "maxProperties": 50,
          "title": "Sanitized Details",
          "type": "object"
        },
        "schema_version": {
          "const": "v1",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "code",
        "message",
        "retryable",
        "occurred_at",
        "correlation_id"
      ],
      "title": "AgentErrorV1",
      "type": "object"
    },
    "ApprovedHttpMethodV1": {
      "enum": [
        "GET",
        "POST"
      ],
      "title": "ApprovedHttpMethodV1",
      "type": "string"
    },
    "AttackEvidenceV1": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Attempt Id",
          "type": "string"
        },
        "campaign_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Campaign Id",
          "type": "string"
        },
        "completed_at": {
          "format": "date-time",
          "title": "Completed At",
          "type": "string"
        },
        "errors": {
          "items": {
            "$ref": "#/$defs/AgentErrorV1"
          },
          "maxItems": 20,
          "title": "Errors",
          "type": "array"
        },
        "evidence_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Hash",
          "type": "string"
        },
        "executed_action_sequence": {
          "items": {
            "$ref": "#/$defs/ExecutedActionV1"
          },
          "maxItems": 30,
          "minItems": 1,
          "title": "Executed Action Sequence",
          "type": "array"
        },
        "langfuse_trace_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Langfuse Trace Id"
        },
        "sanitized_http_metadata": {
          "items": {
            "$ref": "#/$defs/SanitizedHttpExchangeV1"
          },
          "maxItems": 100,
          "title": "Sanitized Http Metadata",
          "type": "array"
        },
        "schema_version": {
          "const": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "side_effects": {
          "items": {
            "$ref": "#/$defs/SideEffectV1"
          },
          "maxItems": 50,
          "title": "Side Effects",
          "type": "array"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "target_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Target Id",
          "type": "string"
        },
        "target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Target Version",
          "type": "string"
        },
        "target_visible_tool_calls": {
          "items": {
            "$ref": "#/$defs/TargetVisibleToolCallV1"
          },
          "maxItems": 100,
          "title": "Target Visible Tool Calls",
          "type": "array"
        },
        "total_latency_ms": {
          "minimum": 0.0,
          "title": "Total Latency Ms",
          "type": "number"
        },
        "transcript": {
          "items": {
            "$ref": "#/$defs/TranscriptTurnV1"
          },
          "maxItems": 100,
          "title": "Transcript",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "target_id",
        "campaign_id",
        "attempt_id",
        "target_version",
        "executed_action_sequence",
        "started_at",
        "completed_at",
        "total_latency_ms",
        "evidence_hash"
      ],
      "title": "AttackEvidenceV1",
      "type": "object"
    },
    "AuthenticateActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "authenticate",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_role": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Expected Role",
          "type": "string"
        },
        "session_source": {
          "$ref": "#/$defs/AuthenticationSessionSourceV1"
        },
        "test_identity_alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Test Identity Alias",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "session_source",
        "test_identity_alias",
        "expected_role"
      ],
      "title": "AuthenticateActionV1",
      "type": "object"
    },
    "AuthenticationSessionSourceV1": {
      "enum": [
        "environment_credentials",
        "ephemeral_saved_test_session"
      ],
      "title": "AuthenticationSessionSourceV1",
      "type": "string"
    },
    "CollectEvidenceActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "collect_evidence",
          "title": "Action Type",
          "type": "string"
        },
        "capture_on": {
          "default": "always",
          "enum": [
            "always",
            "failure",
            "confirmed_signal"
          ],
          "title": "Capture On",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_kinds": {
          "items": {
            "$ref": "#/$defs/EvidenceKindV1"
          },
          "maxItems": 6,
          "minItems": 1,
          "title": "Evidence Kinds",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "evidence_kinds"
      ],
      "title": "CollectEvidenceActionV1",
      "type": "object"
    },
    "ConfirmedFindingSnapshotV1": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Category",
          "type": "string"
        },
        "clinical_impact": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Clinical Impact",
          "type": "string"
        },
        "description": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_behavior": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Expected Behavior",
          "type": "string"
        },
        "finding_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Finding Id",
          "type": "string"
        },
        "first_seen_target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "First Seen Target Version",
          "type": "string"
        },
        "frozen_at": {
          "format": "date-time",
          "title": "Frozen At",
          "type": "string"
        },
        "last_seen_target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Last Seen Target Version",
          "type": "string"
        },
        "observed_behavior": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Observed Behavior",
          "type": "string"
        },
        "owasp_mappings": {
          "$ref": "#/$defs/OwaspMappingsV1"
        },
        "severity": {
          "$ref": "#/$defs/SeverityV1"
        },
        "source_attempt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Source Attempt Id",
          "type": "string"
        },
        "source_fingerprint": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Fingerprint",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/FindingStatusV1"
        },
        "subcategory": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Subcategory",
          "type": "string"
        },
        "title": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "vulnerability_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Vulnerability Id",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "vulnerability_id",
        "source_attempt_id",
        "source_fingerprint",
        "title",
        "severity",
        "status",
        "category",
        "subcategory",
        "owasp_mappings",
        "description",
        "clinical_impact",
        "observed_behavior",
        "expected_behavior",
        "first_seen_target_version",
        "last_seen_target_version",
        "frozen_at"
      ],
      "title": "ConfirmedFindingSnapshotV1",
      "type": "object"
    },
    "EvidenceKindV1": {
      "enum": [
        "transcript",
        "http_metadata",
        "tool_calls",
        "side_effects",
        "screenshot",
        "browser_trace"
      ],
      "title": "EvidenceKindV1",
      "type": "string"
    },
    "ExecutedActionV1": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "discriminator": {
            "mapping": {
              "authenticate": "#/$defs/AuthenticateActionV1",
              "collect_evidence": "#/$defs/CollectEvidenceActionV1",
              "invoke_approved_api_request": "#/$defs/InvokeApprovedApiRequestActionV1",
              "reset_session": "#/$defs/ResetSessionActionV1",
              "select_synthetic_patient": "#/$defs/SelectSyntheticPatientActionV1",
              "send_chat_message": "#/$defs/SendChatMessageActionV1",
              "upload_approved_fixture": "#/$defs/UploadApprovedFixtureActionV1",
              "wait_for_response": "#/$defs/WaitForResponseActionV1"
            },
            "propertyName": "action_type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/ResetSessionActionV1"
            },
            {
              "$ref": "#/$defs/AuthenticateActionV1"
            },
            {
              "$ref": "#/$defs/SelectSyntheticPatientActionV1"
            },
            {
              "$ref": "#/$defs/SendChatMessageActionV1"
            },
            {
              "$ref": "#/$defs/UploadApprovedFixtureActionV1"
            },
            {
              "$ref": "#/$defs/InvokeApprovedApiRequestActionV1"
            },
            {
              "$ref": "#/$defs/WaitForResponseActionV1"
            },
            {
              "$ref": "#/$defs/CollectEvidenceActionV1"
            }
          ],
          "title": "Action"
        },
        "completed_at": {
          "format": "date-time",
          "title": "Completed At",
          "type": "string"
        },
        "sanitized_result_summary": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sanitized Result Summary"
        },
        "sequence_index": {
          "maximum": 100,
          "minimum": 0,
          "title": "Sequence Index",
          "type": "integer"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ActionExecutionStatusV1"
        }
      },
      "required": [
        "sequence_index",
        "action",
        "status",
        "started_at",
        "completed_at"
      ],
      "title": "ExecutedActionV1",
      "type": "object"
    },
    "ExploitabilityV1": {
      "enum": [
        "high",
        "medium",
        "low",
        "not_applicable"
      ],
      "title": "ExploitabilityV1",
      "type": "string"
    },
    "FindingStatusV1": {
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "reopened",
        "false_positive"
      ],
      "title": "FindingStatusV1",
      "type": "string"
    },
    "FixValidationResultV1": {
      "additionalProperties": false,
      "properties": {
        "evidence_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Hash"
        },
        "outcome": {
          "$ref": "#/$defs/ValidationOutcomeV1"
        },
        "regression_run_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Regression Run Id"
        },
        "summary": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Target Version",
          "type": "string"
        },
        "validated_at": {
          "format": "date-time",
          "title": "Validated At",
          "type": "string"
        }
      },
      "required": [
        "target_version",
        "outcome",
        "validated_at",
        "summary"
      ],
      "title": "FixValidationResultV1",
      "type": "object"
    },
    "InvokeApprovedApiRequestActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "invoke_approved_api_request",
          "title": "Action Type",
          "type": "string"
        },
        "body": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Body",
          "type": "object"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "endpoint_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Endpoint Id",
          "type": "string"
        },
        "method": {
          "$ref": "#/$defs/ApprovedHttpMethodV1"
        },
        "query": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "maxProperties": 25,
          "title": "Query",
          "type": "object"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "endpoint_id",
        "method"
      ],
      "title": "InvokeApprovedApiRequestActionV1",
      "type": "object"
    },
    "JsonValue": {},
    "JudgeVerdictKindV1": {
      "enum": [
        "exploit_confirmed",
        "partial_signal",
        "attack_blocked",
        "inconclusive"
      ],
      "title": "JudgeVerdictKindV1",
      "type": "string"
    },
    "JudgeVerdictV1": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "expected_behavior": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Expected Behavior",
          "type": "string"
        },
        "exploitability": {
          "$ref": "#/$defs/ExploitabilityV1"
        },
        "observed_behavior": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Observed Behavior",
          "type": "string"
        },
        "rubric_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Rubric Hash",
          "type": "string"
        },
        "rubric_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Rubric Version",
          "type": "string"
        },
        "schema_version": {
          "const": "v1",
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/SeverityV1"
        },
        "verdict": {
          "$ref": "#/$defs/JudgeVerdictKindV1"
        },
        "violated_security_invariants": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Violated Security Invariants",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "verdict",
        "severity",
        "exploitability",
        "confidence",
        "observed_behavior",
        "expected_behavior",
        "rubric_version",
        "rubric_hash"
      ],
      "title": "JudgeVerdictV1",
      "type": "object"
    },
    "OwaspMappingsV1": {
      "additionalProperties": false,
      "description": "Explicitly versioned OWASP mappings; versions may not be implicit.",
      "properties": {
        "llm_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Llm Top 10",
          "type": "array"
        },
        "llm_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Llm Top 10 Version",
          "type": "string"
        },
        "web_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Web Top 10",
          "type": "array"
        },
        "web_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Web Top 10 Version",
          "type": "string"
        }
      },
      "required": [
        "web_top_10_version",
        "llm_top_10_version"
      ],
      "title": "OwaspMappingsV1",
      "type": "object"
    },
    "ResetSessionActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "reset_session",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "require_clean_context": {
          "default": true,
          "title": "Require Clean Context",
          "type": "boolean"
        },
        "reset_strategy_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Reset Strategy Id",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
