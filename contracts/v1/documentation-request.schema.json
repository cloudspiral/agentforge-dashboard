{
  "$defs": {
    "ApprovedHttpMethodV1": {
      "enum": [
        "GET",
        "POST"
      ],
      "title": "ApprovedHttpMethodV1",
      "type": "string"
    },
    "AssertionOutcomeV1": {
      "enum": [
        "passed",
        "failed",
        "error",
        "not_applicable"
      ],
      "title": "AssertionOutcomeV1",
      "type": "string"
    },
    "AuthenticateActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "authenticate",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_role": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Expected Role",
          "type": "string"
        },
        "session_source": {
          "$ref": "#/$defs/AuthenticationSessionSourceV1"
        },
        "test_identity_alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Test Identity Alias",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "session_source",
        "test_identity_alias",
        "expected_role"
      ],
      "title": "AuthenticateActionV1",
      "type": "object"
    },
    "AuthenticationSessionSourceV1": {
      "enum": [
        "environment_credentials",
        "ephemeral_saved_test_session"
      ],
      "title": "AuthenticationSessionSourceV1",
      "type": "string"
    },
    "CollectEvidenceActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "collect_evidence",
          "title": "Action Type",
          "type": "string"
        },
        "capture_on": {
          "default": "always",
          "enum": [
            "always",
            "failure",
            "confirmed_signal"
          ],
          "title": "Capture On",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_kinds": {
          "items": {
            "$ref": "#/$defs/EvidenceKindV1"
          },
          "maxItems": 6,
          "minItems": 1,
          "title": "Evidence Kinds",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "evidence_kinds"
      ],
      "title": "CollectEvidenceActionV1",
      "type": "object"
    },
    "ConfirmedFindingSnapshotV1": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Category",
          "type": "string"
        },
        "clinical_impact": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Clinical Impact",
          "type": "string"
        },
        "deduplication_fingerprint": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Deduplication Fingerprint",
          "type": "string"
        },
        "description": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "expected_behavior": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Expected Behavior",
          "type": "string"
        },
        "finding_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Finding Id",
          "type": "string"
        },
        "first_seen_target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "First Seen Target Version",
          "type": "string"
        },
        "frozen_at": {
          "format": "date-time",
          "title": "Frozen At",
          "type": "string"
        },
        "last_seen_target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Last Seen Target Version",
          "type": "string"
        },
        "observed_behavior": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Observed Behavior",
          "type": "string"
        },
        "owasp_mappings": {
          "$ref": "#/$defs/OwaspMappingsV1"
        },
        "severity": {
          "$ref": "#/$defs/SeverityV1"
        },
        "source_attempt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Source Attempt Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/FindingStatusV1"
        },
        "subcategory": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Subcategory",
          "type": "string"
        },
        "title": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "vulnerability_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Vulnerability Id",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "vulnerability_id",
        "source_attempt_id",
        "deduplication_fingerprint",
        "title",
        "severity",
        "status",
        "category",
        "subcategory",
        "owasp_mappings",
        "description",
        "clinical_impact",
        "observed_behavior",
        "expected_behavior",
        "first_seen_target_version",
        "last_seen_target_version",
        "frozen_at"
      ],
      "title": "ConfirmedFindingSnapshotV1",
      "type": "object"
    },
    "DeterministicAssertionResultV1": {
      "additionalProperties": false,
      "properties": {
        "assertion_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Assertion Id",
          "type": "string"
        },
        "evidence_reference_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 20,
          "title": "Evidence Reference Ids",
          "type": "array"
        },
        "expected": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Expected",
          "type": "string"
        },
        "invariant_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Invariant Id",
          "type": "string"
        },
        "observed": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Observed",
          "type": "string"
        },
        "outcome": {
          "$ref": "#/$defs/AssertionOutcomeV1"
        }
      },
      "required": [
        "assertion_id",
        "invariant_id",
        "outcome",
        "expected",
        "observed"
      ],
      "title": "DeterministicAssertionResultV1",
      "type": "object"
    },
    "EvidenceKindV1": {
      "enum": [
        "transcript",
        "http_metadata",
        "tool_calls",
        "side_effects",
        "screenshot",
        "browser_trace"
      ],
      "title": "EvidenceKindV1",
      "type": "string"
    },
    "EvidenceReferenceKindV1": {
      "enum": [
        "transcript",
        "http_metadata",
        "tool_call",
        "assertion",
        "screenshot",
        "browser_trace",
        "langfuse_trace",
        "report",
        "other"
      ],
      "title": "EvidenceReferenceKindV1",
      "type": "string"
    },
    "EvidenceReferenceV1": {
      "additionalProperties": false,
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Path"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceReferenceKindV1"
        },
        "reference_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Reference Id",
          "type": "string"
        }
      },
      "required": [
        "reference_id",
        "kind",
        "description"
      ],
      "title": "EvidenceReferenceV1",
      "type": "object"
    },
    "FindingStatusV1": {
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "reopened",
        "false_positive"
      ],
      "title": "FindingStatusV1",
      "type": "string"
    },
    "FixValidationResultV1": {
      "additionalProperties": false,
      "properties": {
        "evidence_references": {
          "items": {
            "$ref": "#/$defs/EvidenceReferenceV1"
          },
          "maxItems": 50,
          "title": "Evidence References",
          "type": "array"
        },
        "outcome": {
          "$ref": "#/$defs/ValidationOutcomeV1"
        },
        "regression_run_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Regression Run Id"
        },
        "summary": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Target Version",
          "type": "string"
        },
        "validated_at": {
          "format": "date-time",
          "title": "Validated At",
          "type": "string"
        }
      },
      "required": [
        "target_version",
        "outcome",
        "validated_at",
        "summary"
      ],
      "title": "FixValidationResultV1",
      "type": "object"
    },
    "InvokeApprovedApiRequestActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "invoke_approved_api_request",
          "title": "Action Type",
          "type": "string"
        },
        "body": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Body",
          "type": "object"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "endpoint_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Endpoint Id",
          "type": "string"
        },
        "method": {
          "$ref": "#/$defs/ApprovedHttpMethodV1"
        },
        "query": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "maxProperties": 25,
          "title": "Query",
          "type": "object"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "endpoint_id",
        "method"
      ],
      "title": "InvokeApprovedApiRequestActionV1",
      "type": "object"
    },
    "JsonValue": {},
    "MinimalEvidencePackageV1": {
      "additionalProperties": false,
      "properties": {
        "deterministic_assertion_results": {
          "items": {
            "$ref": "#/$defs/DeterministicAssertionResultV1"
          },
          "maxItems": 50,
          "title": "Deterministic Assertion Results",
          "type": "array"
        },
        "evidence_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Hash",
          "type": "string"
        },
        "evidence_references": {
          "items": {
            "$ref": "#/$defs/EvidenceReferenceV1"
          },
          "maxItems": 50,
          "minItems": 1,
          "title": "Evidence References",
          "type": "array"
        },
        "exact_action_sequence": {
          "items": {
            "discriminator": {
              "mapping": {
                "authenticate": "#/$defs/AuthenticateActionV1",
                "collect_evidence": "#/$defs/CollectEvidenceActionV1",
                "invoke_approved_api_request": "#/$defs/InvokeApprovedApiRequestActionV1",
                "reset_session": "#/$defs/ResetSessionActionV1",
                "select_synthetic_patient": "#/$defs/SelectSyntheticPatientActionV1",
                "send_chat_message": "#/$defs/SendChatMessageActionV1",
                "upload_approved_fixture": "#/$defs/UploadApprovedFixtureActionV1",
                "wait_for_response": "#/$defs/WaitForResponseActionV1"
              },
              "propertyName": "action_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ResetSessionActionV1"
              },
              {
                "$ref": "#/$defs/AuthenticateActionV1"
              },
              {
                "$ref": "#/$defs/SelectSyntheticPatientActionV1"
              },
              {
                "$ref": "#/$defs/SendChatMessageActionV1"
              },
              {
                "$ref": "#/$defs/UploadApprovedFixtureActionV1"
              },
              {
                "$ref": "#/$defs/InvokeApprovedApiRequestActionV1"
              },
              {
                "$ref": "#/$defs/WaitForResponseActionV1"
              },
              {
                "$ref": "#/$defs/CollectEvidenceActionV1"
              }
            ]
          },
          "maxItems": 30,
          "minItems": 1,
          "title": "Exact Action Sequence",
          "type": "array"
        },
        "target_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Target Version",
          "type": "string"
        },
        "transcript_excerpts": {
          "items": {
            "$ref": "#/$defs/TranscriptTurnV1"
          },
          "maxItems": 30,
          "title": "Transcript Excerpts",
          "type": "array"
        }
      },
      "required": [
        "evidence_hash",
        "target_version",
        "exact_action_sequence",
        "evidence_references"
      ],
      "title": "MinimalEvidencePackageV1",
      "type": "object"
    },
    "OwaspMappingsV1": {
      "additionalProperties": false,
      "description": "Explicitly versioned OWASP mappings; versions may not be implicit.",
      "properties": {
        "llm_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Llm Top 10",
          "type": "array"
        },
        "llm_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Llm Top 10 Version",
          "type": "string"
        },
        "web_top_10": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 10,
          "title": "Web Top 10",
          "type": "array"
        },
        "web_top_10_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Web Top 10 Version",
          "type": "string"
        }
      },
      "required": [
        "web_top_10_version",
        "llm_top_10_version"
      ],
      "title": "OwaspMappingsV1",
      "type": "object"
    },
    "ResetSessionActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "reset_session",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "require_clean_context": {
          "default": true,
          "title": "Require Clean Context",
          "type": "boolean"
        },
        "reset_strategy_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Reset Strategy Id",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "reset_strategy_id"
      ],
      "title": "ResetSessionActionV1",
      "type": "object"
    },
    "SelectSyntheticPatientActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "select_synthetic_patient",
          "title": "Action Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "patient_alias": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Patient Alias",
          "type": "string"
        },
        "verify_selected_context": {
          "default": true,
          "title": "Verify Selected Context",
          "type": "boolean"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "patient_alias"
      ],
      "title": "SelectSyntheticPatientActionV1",
      "type": "object"
    },
    "SendChatMessageActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "send_chat_message",
          "title": "Action Type",
          "type": "string"
        },
        "await_response": {
          "default": true,
          "title": "Await Response",
          "type": "boolean"
        },
        "conversation_alias": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conversation Alias"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "message": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "message"
      ],
      "title": "SendChatMessageActionV1",
      "type": "object"
    },
    "SeverityV1": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational",
        "none"
      ],
      "title": "SeverityV1",
      "type": "string"
    },
    "TranscriptRoleV1": {
      "enum": [
        "user",
        "assistant",
        "tool",
        "system"
      ],
      "title": "TranscriptRoleV1",
      "type": "string"
    },
    "TranscriptTurnV1": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "role": {
          "$ref": "#/$defs/TranscriptRoleV1"
        },
        "turn_index": {
          "maximum": 1000,
          "minimum": 0,
          "title": "Turn Index",
          "type": "integer"
        }
      },
      "required": [
        "turn_index",
        "role",
        "content",
        "observed_at"
      ],
      "title": "TranscriptTurnV1",
      "type": "object"
    },
    "UploadApprovedFixtureActionV1": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "upload_approved_fixture",
          "title": "Action Type",
          "type": "string"
        },
        "declared_media_type": {
          "maxLength": 100,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9.+-]+/[A-Za-z0-9.+-]+$",
          "title": "Declared Media Type",
          "type": "string"
        },
        "description": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "fixture_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Fixture Id",
          "type": "string"
        },
        "upload_surface_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Upload Surface Id",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "description",
        "action_type",
        "fixture_id",
        "upload_surface_id",
        "declared_media_type"
      ],
      "title": "UploadApprovedFixtureActionV1",
      "type": "object"
    },
    "ValidationOutcomeV1": {
      "enum": [
        "secure_pass",
