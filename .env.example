# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://agentforge:agentforge@postgres:5432/agentforge
PLATFORM_API_TOKEN=replace-with-a-long-random-token
DEPLOY_WEBHOOK_SECRET=replace-with-a-distinct-long-random-token
DASHBOARD_AUTH_USERNAME=
DASHBOARD_AUTH_PASSWORD=

# OpenAI Agents SDK. Keep all roles independently overridable.
OPENAI_API_KEY=
OPENAI_ORCHESTRATOR_MODEL=gpt-5.6-terra
OPENAI_ATTACK_MODEL=gpt-5.6-terra
OPENAI_JUDGE_MODEL=gpt-5.6-terra
OPENAI_JUDGE_ESCALATION_MODEL=gpt-5.6-sol
OPENAI_DOCUMENTATION_MODEL=gpt-5.6-luna
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=0
OPENAI_AGENTS_DONT_LOG_MODEL_DATA=1
OPENAI_AGENTS_DONT_LOG_TOOL_DATA=1
OPENINFERENCE_HIDE_INPUTS=true
OPENINFERENCE_HIDE_OUTPUTS=true
OPENINFERENCE_HIDE_LLM_TOOLS=true
OPENINFERENCE_HIDE_LLM_INVOCATION_PARAMETERS=true
GLOBAL_MAX_COST_USD=20
DEFAULT_CAMPAIGN_MAX_COST_USD=8
DEFAULT_CAMPAIGN_MAX_ATTEMPTS=30
DEFAULT_CAMPAIGN_MAX_DURATION_SECONDS=21600
REGRESSION_RESERVE_MIN_USD=3
REGRESSION_RESERVE_MULTIPLIER=1.25
DEFAULT_MAX_MUTATIONS=3
DEFAULT_NO_SIGNAL_LIMIT=4

# Langfuse is fail-open for telemetry only; application evidence remains in PostgreSQL.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_TRACING_ENABLED=true

# The only authorized target is supplied by this checked-in profile and host allowlist.
TARGET_PROFILE_PATH=config/target-profile.yaml
ATTACK_TAXONOMY_PATH=config/attack-taxonomy.yaml
JUDGE_RUBRIC_PATH=config/judge-rubric.yaml
MODEL_ROUTING_PATH=config/model-routing.yaml
PRICING_PATH=config/pricing.yaml
TARGET_BASE_URL=https://host.docker.internal:9300
TARGET_API_BASE_URL=http://host.docker.internal:8001
TARGET_UI_URL=https://host.docker.internal:9300
TARGET_ALLOWED_HOSTS=host.docker.internal,localhost,127.0.0.1
TARGET_VERSION=local-unknown
TARGET_TEST_USERNAME=
TARGET_TEST_PASSWORD=
TARGET_TEST_ROLE=physician
TARGET_TEST_PATIENT_A_ID=
TARGET_TEST_PATIENT_B_ID=
TARGET_TEST_USER_ID=
TARGET_AGENT_SHARED_SECRET=
TARGET_RESET_URL=
TARGET_RESET_TOKEN=
TARGET_VERIFY_TLS=false
TARGET_PROBE_TIMEOUT_SECONDS=3
TARGET_UI_SMOKE_TIMEOUT_SECONDS=30
TARGET_UI_SMOKE_HEADLESS=true
TARGET_UI_SMOKE_SCREENSHOT_ON_FAILURE=false
AGENTFORGE_UI_IGNORE_HTTPS_ERRORS=false
AGENTFORGE_BROWSER_CHANNEL=auto

# Explicit opt-in for live browser execution. Deployed evaluations additionally
# enforce normal TLS verification, headless mode, and Playwright-managed Chromium.
RUN_LIVE_E2E=0

# Worker and artifact controls
WORKER_ENABLED=true
WORKER_POLL_SECONDS=2
WORKER_STALE_AFTER_SECONDS=120
REPORTS_DIR=reports/generated
ARTIFACTS_DIR=artifacts
MAX_UPLOAD_BYTES=1048576
